# Public API base URL for frontend requests
# Example: https://api.example.com/api
VITE_API_BASE_URL=https://api.example.com/api

# Public backend origin used for opening uploaded files/images
# Example: https://api.example.com
VITE_BACKEND_URL=https://api.example.com

# Google Maps Embed API key for Street View modal
# Restrict by HTTP referrer and allow your panel domain(s)
VITE_GOOGLE_MAPS_EMBED_API_KEY=YOUR_GOOGLE_MAPS_EMBED_API_KEY
